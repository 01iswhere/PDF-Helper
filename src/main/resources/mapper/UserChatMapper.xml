<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zero1iswhere.pdfhelper.mapper.UserChatMapper">

    <insert id="addUserChat">
        insert into user_chat(user_name, chat_id) values (#{userName}, #{chatId})
    </insert>
    <select id="getChatIdStatus" resultType="java.lang.Integer">
        select status from user_chat where user_name=#{userName} and chat_id=#{chatId}
    </select>
    <select id="getAllChatIds" resultType="java.lang.String">
        select chat_id from user_chat where user_name=#{userName} and status=1;
    </select>
</mapper>